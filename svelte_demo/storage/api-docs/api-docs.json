                                    "description": {
                                        "type": "string"
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 19.99
                                    },
                                    "stock_qty": {
                                        "type": "integer",
                                        "example": 10
                                    },
                                    "condition": {
                                        "type": "string",
                                        "example": "new"
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "active"
                                    },
                                    "video_url": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "images": {
                                        "type": "array",
                                        "items": {
                                            "properties": {
                                                "image_url": {
                                                    "type": "string",
                                                    "example": "book-images/cover.jpg"
                                                },
                                                "is_primary": {
                                                    "type": "boolean",
                                                    "example": true
                                                }
