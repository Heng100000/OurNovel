                "operationId": "72f82e1cd6f08112323f87053277ca99",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "title",
                                    "author_id",
                                    "category_id",
                                    "description",
                                    "price",
                                    "stock_qty",
                                    "condition",
                                    "status"
                                ],
                                "properties": {
                                    "title": {
                                        "type": "string",
                                        "example": "The Great Gatsby"
                                    },
                                    "author_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "category_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "promotion_id": {
                                        "type": "integer",
                                        "nullable": true
                                    },
                                    "isbn": {
                                        "type": "string",
                                        "example": "978-3-16-148410-0"
